{
  "version": "1.7.5",
  "description": "Source of truth for fundamental data keys across portals. Verified strictly against non-mock raw records and specialized test JSONs.",
  "portals": {
    "rp": {
      "name": "RynekPierwotny",
      "investment": {
        "id": "id",
        "slug": "slug",
        "investment_slug": "slug",
        "name": "name",
        "developer_id": "vendor.value.id|vendor.id|developer_id|vendor_id",
        "vendor_id": "vendor.value.id|vendor.id|developer_id|vendor_id",
        "developer_slug": {
          "path": "vendor.value.slug|vendor.slug|developer_slug|vendor_slug",
          "regex": "^[a-z0-9\\-]+$"
        },
        "developer_name": "vendor.value.name|vendor.name|developer_name|vendor_name",
        "units_count": "stats.value.properties_count_for_sale|stats.properties_count_for_sale",
        "price_min": "stats.value.ranges_price_min|stats.ranges_price_min",
        "price_max": "stats.value.ranges_price_max|stats.ranges_price_max",
        "price_m2_min": "stats.value.ranges_price_m2_min|stats.ranges_price_m2_min",
        "price_m2_max": "stats.value.ranges_price_m2_max|stats.ranges_price_m2_max",
        "ceiling_height_min": {
          "path": "stats.value.ranges_height_min|stats.ranges_height_min",
          "transform": "cm_to_m"
        },
        "ceiling_height_max": {
          "path": "stats.value.ranges_height_max|stats.ranges_height_max",
          "transform": "cm_to_m"
        },
        "address": "address.value|address",
        "city": {
          "path": "address.value|address",
          "transform": "rp_extract_city"
        },
        "street": {
          "path": "address.value|address",
          "transform": "rp_extract_street"
        },
        "region": {
          "path": "address.value|address",
          "transform": "rp_extract_region"
        },
        "website": "website",
        "geo_point": "geo_point.coordinates|geo_point.value.coordinates.value",
        "geo_point_coordinates": "geo_point.coordinates|geo_point.value.coordinates.value",
        "latitude": "geo_point.coordinates[1]|geo_point.value.coordinates.value[1]",
        "longitude": "geo_point.coordinates[0]|geo_point.value.coordinates.value[0]",
        "construction_date_upper": "construction_date_range.value.upper|construction_date_range.upper",
        "main_image": "main_image",
        "gallery": {
          "path": ".",
          "transform": "rp_gallery_to_flat_list"
        },
        "groups": "groups",
        "groups_id": "groups.id",
        "groups_name": "groups.name",
        "groups_stages": "groups.stages",
        "segment": {
          "evaluate_signals": {
            "commercial": "stats.value.properties_commercials_count|stats.properties_commercials_count",
            "apartments": "properties|properties_for_sale_count|stats.value.properties_count_for_sale|stats.properties_count_for_sale",
            "houses": "stats.value.all_house_types|stats.all_house_types|stats.value.ranges_plot_area_max|stats.ranges_plot_area_max"
          },
          "fallback": "investment"
        },
        "transaction_type": {
          "evaluate_signals": {
            "rent": "commercial_rental"
          },
          "fallback": "sale"
        },
        "amenities": {
          "path": "features",
          "transform": "rp_extract_amenities"
        }
      },
      "developer": {
        "id": "id",
        "slug": "slug",
        "name": "name"
      },
      "stage": {
        "id": "id",
        "offer_id": "offer.id",
        "offer_slug": "offer.slug",
        "offer_name": "offer.name",
        "vendor_name": "offer.vendor.name",
        "vendor_slug": "offer.vendor.slug"
      }
    },
    "oto": {
      "name": "Otodom",
      "investment": {
        "id": "id|ad.id|oto_url_id",
        "numeric_id": "ad.id",
        "slug": {
          "path": "ad.slug",
          "regex": "^(.*?)(?:-ID[A-Za-z0-9]+)?$"
        },
        "investment_slug": {
          "path": "ad.slug",
          "regex": "^(.*?)(?:-ID[A-Za-z0-9]+)?$"
        },
        "name": "ad.title|title",
        "developer_id": "ad.agency.id|agency_id|owner.id",
        "vendor_id": "ad.agency.id|agency_id|owner.id",
        "developer_name": "ad.agency.name|agency_name|owner.name",
        "developer_slug": {
          "path": "ad.agency.url",
          "regex": "deweloperzy/([^/]+)-ID\\d+"
        },
        "units_count": "ad.target.Number_of_properties",
        "price_min": "ad.target.Price",
        "price_m2_min": {
          "path": "ad.characteristics[key=price_per_m].value",
          "unit": "PLN/m2"
        },
        "price_m2_max": {
          "path": "ad.characteristics[key=price_per_m].value",
          "unit": "PLN/m2"
        },
        "ceiling_height_min": {
          "path": "ad.characteristics[key=ceiling_height].value",
          "transform": "cm_to_m",
          "unit": "m"
        },
        "ceiling_height_max": {
          "path": "ad.characteristics[key=ceiling_height].value",
          "transform": "cm_to_m",
          "unit": "m"
        },
        "latitude": "ad.location.coordinates.latitude",
        "longitude": "ad.location.coordinates.longitude",
        "address": {
          "path": "ad.location.address.street.name",
          "transform": "clean_street"
        },
        "city": "ad.location.address.city.name",
        "street": {
          "path": "ad.location.address.street.name",
          "transform": "clean_street"
        },
        "region": "ad.location.address.district.name",
        "geo_point": {
          "lat": "ad.location.coordinates.latitude",
          "lon": "ad.location.coordinates.longitude"
        },
        "status": "ad.status",
        "delivery_raw": "ad.topInformation",
        "delivery_fallback_quarter": "ad.investmentEstimatedDelivery.quarter",
        "delivery_fallback_year": "ad.investmentEstimatedDelivery.year",
        "images": {
          "path": "ad.images",
          "transform": "oto_gallery_to_flat_list"
        },
        "url": "ad.url|url",
        "developer_url": "ad.agency.url",
        "owner_name": "ad.owner.name|owner.account.name|owner.name",
        "hash_id": {
          "path": "ad.url|url|ad.slug",
          "regex": "-ID([A-Za-z0-9]+)"
        },
        "segment": {
          "evaluate_signals": {
            "commercial": {
              "path": "ad.target.categoryId",
              "regex": "501"
            },
            "apartments": {
              "path": "ad.target.categoryId",
              "regex": "11"
            },
            "houses": {
              "path": "ad.target.categoryId",
              "regex": "13"
            }
          },
          "fallback": "investment"
        },
        "transaction_type": {
          "evaluate_signals": {
            "rent": {
              "path": "ad.target.MarketType",
              "regex": "rent"
            }
          },
          "fallback": "sale"
        },
        "delivery_date": {
          "path": "ad.topInformation",
          "transform": "oto_extract_delivery"
        }
      },
      "developer": {
        "id": "owner.id",
        "slug": {
          "path": "owner.account.attributes.slug",
          "regex": "([^/]+)-ID\\d+"
        },
        "name": "owner.account.name"
      }
    },
    "to": {
      "name": "TabelaOfert",
      "investment": {
        "id": {
          "path": "url",
          "regex": ",i(\\d+)"
        },
        "slug": {
          "path": "url",
          "regex": "inwestycja/([^,]+)"
        },
        "investment_slug": {
          "path": "url",
          "regex": "inwestycja/([^,]+)"
        },
        "name": "name",
        "developer_id": {
          "path": "brand.logo",
          "regex": "\\/(\\d+)-"
        },
        "vendor_id": {
          "path": "brand.logo",
          "regex": "\\/(\\d+)-"
        },
        "developer_name": "brand.name",
        "developer_slug": "developer_slug",
        "units_count": "offers.offerCount",
        "price_min": "offers.lowPrice",
        "price_max": "offers.highPrice",
        "price_m2_min": {
          "path": "offers.pricePerSqm",
          "unit": "PLN/m2"
        },
        "price_m2_max": {
          "path": "offers.pricePerSqm",
          "unit": "PLN/m2"
        },
        "ceiling_height_min": {
          "path": "additionalProperty[name=Wysokość mieszkania].value|additionalProperty[name=Wys. apartamentu inwestycyjnego].value",
          "transform": "cm_to_m",
          "unit": "m"
        },
        "ceiling_height_max": {
          "path": "additionalProperty[name=Wysokość mieszkania].value|additionalProperty[name=Wys. apartamentu inwestycyjnego].value",
          "transform": "cm_to_m",
          "unit": "m"
        },
        "latitude": "_raw_mapa.data.center.y",
        "longitude": "_raw_mapa.data.center.x",
        "address": "_extracted_location.address",
        "city": "_extracted_location.city",
        "street": {
          "path": "_extracted_location.street",
          "transform": "clean_street"
        },
        "region": "_extracted_location.region",
        "brand_klient_id": "brand.klientId",
        "publisher_klient_id": "publisher.klientId",
        "klient_id": "klientId|klient_id",
        "offers_list": "offers.offers",
        "segment": {
          "evaluate_signals": {
            "commercial": {
              "path": "url",
              "regex": "lokale-uzytkowe"
            },
            "apartments": {
              "path": "url",
              "regex": "mieszkania-na-sprzedaz"
            },
            "houses": {
              "path": "url",
              "regex": "domy-na-sprzedaz"
            }
          },
          "fallback": "investment"
        },
        "transaction_type": {
          "evaluate_signals": {
            "rent": {
              "path": "url",
              "regex": "na-wynajem"
            }
          },
          "fallback": "sale"
        },
        "amenities": {
          "path": "additionalProperty",
          "transform": "to_extract_amenities"
        }
      },
      "developer": {
        "id": {
          "path": "logo_url|logo",
          "regex": ",(\\d+)-/"
        },
        "slug": {
          "path": "url",
          "regex": "deweloperzy/([^/]+)$"
        },
        "name": "name|nazwa"
      }
    }
  }
}